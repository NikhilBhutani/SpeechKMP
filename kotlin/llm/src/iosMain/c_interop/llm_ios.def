headers = deviceai_llm_engine.h
headerFilter = deviceai_llm_engine.h
compilerOpts = -I$PROJECT_DIR/../../cpp/llm \
               -I$PROJECT_DIR/../llama.cpp/include \
               -I$PROJECT_DIR/../llama.cpp
staticLibraries = libllm_merged.a
linkerOpts = -framework Accelerate -framework Metal -framework MetalKit -lc++ -ObjC
package = dev.deviceai.llm.native
